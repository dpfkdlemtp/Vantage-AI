# Export this file in your shell before running phase workers.
# The project does not auto-load .env files.
# No environment variables are required by default.

# --- ai_triage phase (LLM-in-the-loop) ---
# Optional. When set, the ai_triage phase uses an LLM to risk-score findings and
# (in "act" mode) autonomously enqueue deeper, scope-locked scans. Without a key,
# ai_triage still runs using a deterministic offline heuristic.
# ANTHROPIC_API_KEY=sk-ant-...
# For the OpenAI provider (ai_provider=openai), set OPENAI_API_KEY and ai_api_key_env=OPENAI_API_KEY.
# OPENAI_API_KEY=sk-...
